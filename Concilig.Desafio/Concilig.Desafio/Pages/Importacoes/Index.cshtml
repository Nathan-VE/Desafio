@page
@model Concilig.Desafio.Pages.Importacoes.IndexModel
@{
    ViewData["Title"] = "Minhas Importações";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Minhas Importações</h2>
    <a asp-page="/Importacoes/Upload" class="btn btn-primary">+ Nova Importação</a>
</div>

@if (Model.MensagemSucesso != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.MensagemSucesso
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.MensagemAviso != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @Model.MensagemAviso
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Importacoes.Any())
{
    <div class="alert alert-info">
        Nenhuma importação encontrada.
        <a asp-page="/Importacoes/Upload" class="alert-link">Importe um arquivo CSV agora!</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Arquivo</th>
                        <th>Data de Importação</th>
                        <th class="text-center">Registros</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var imp in Model.Importacoes)
                    {
                        <tr>
                            <td>@imp.NomeArquivo</td>
                            <td>@imp.DataImportacao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@imp.QuantidadeRegistros</span>
                            </td>
                            <td class="text-center">
                                <a asp-page="/Importacoes/Detalhes"
                                   asp-route-id="@imp.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Ver detalhes
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Paginação — só aparece quando há mais de uma página *@
    @if (Model.TotalPaginas > 1)
    {
        <nav aria-label="Paginação" class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(Model.PaginaAtual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="/Importacoes/Index"
                       asp-route-pagina="@(Model.PaginaAtual - 1)">Anterior</a>
                </li>

                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaAtual ? "active" : "")">
                        <a class="page-link" asp-page="/Importacoes/Index"
                           asp-route-pagina="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.PaginaAtual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-page="/Importacoes/Index"
                       asp-route-pagina="@(Model.PaginaAtual + 1)">Próxima</a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small mt-2">
            @Model.TotalRegistros importação(ões) no total
        </p>
    }
}
