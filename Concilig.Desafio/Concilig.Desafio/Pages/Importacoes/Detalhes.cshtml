@page "{id:int}"
@model Concilig.Desafio.Pages.Importacoes.DetalhesModel
@using System.Globalization
@{
    ViewData["Title"] = "Detalhes da Importação";
    var ptBR = new CultureInfo("pt-BR");
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-1">@Model.Importacao!.NomeArquivo</h2>
        <p class="text-muted mb-0">
            Importado em @Model.Importacao.DataImportacao.ToString("dd/MM/yyyy HH:mm")
            &mdash;
            <span class="badge bg-secondary">@Model.Importacao.QuantidadeRegistros registro(s)</span>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Importacoes/Clientes" asp-route-id="@Model.Importacao.Id"
           class="btn btn-outline-primary">Resumo por Cliente</a>
        <a asp-page="/Importacoes/Index" class="btn btn-outline-secondary">← Voltar</a>
    </div>
</div>

@* Painel de filtros *@
<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Filtros</div>
    <div class="card-body">
        <form method="get" asp-page="/Importacoes/Detalhes" asp-route-id="@Model.Importacao.Id">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Cliente</label>
                    <input type="text" name="FiltroCliente" value="@Model.FiltroCliente"
                           class="form-control" placeholder="Buscar por nome..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Vencimento de</label>
                    <input type="date" name="DataInicio"
                           value="@Model.DataInicio?.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">até</label>
                    <input type="date" name="DataFim"
                           value="@Model.DataFim?.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Buscar</button>
                    <a asp-page="/Importacoes/Detalhes" asp-route-id="@Model.Importacao.Id"
                       class="btn btn-outline-secondary" title="Limpar filtros">✕</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Contratos.Any())
{
    <div class="alert alert-info">Nenhum contrato encontrado com os filtros aplicados.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Contratos</span>
            <span class="text-muted small">@Model.Contratos.Count resultado(s)</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nº Contrato</th>
                        <th>Cliente</th>
                        <th class="text-end">Valor</th>
                        <th>Vencimento</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contrato in Model.Contratos)
                    {
                        <tr>
                            <td>@contrato.NumeroContrato</td>
                            <td>@contrato.Cliente</td>
                            <td class="text-end">@contrato.Valor.ToString("C", ptBR)</td>
                            <td>@contrato.DataVencimento.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}