@page
@model Concilig.Desafio.Pages.Importacoes.UploadModel
@{
    ViewData["Title"] = "Importar CSV";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Importar arquivo CSV</h2>

        @if (Model.MensagemSucesso != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-1"></i>@Model.MensagemSucesso
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.MensagemAviso != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.MensagemAviso
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.MensagemErro != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-x-circle-fill me-1"></i>@Model.MensagemErro
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form method="post" enctype="multipart/form-data" id="formUpload">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="arquivo" class="form-label fw-semibold">Selecione o arquivo CSV</label>
                        <input type="file" class="form-control" id="arquivo" name="arquivo"
                               accept=".csv" required />
                        <div class="form-text">
                            Formato esperado: <code>NumeroContrato;Cliente;Valor;DataVencimento</code><br />
                            Tamanho máximo: 5 MB. A primeira linha (cabeçalho) será ignorada.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" id="btnImportar">
                        <span id="textoBtn">Importar</span>
                        <span id="loadingBtn" class="d-none">
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            Importando...
                        </span>
                    </button>
                </form>
            </div>
        </div>

        <div class="mt-3 text-center">
            <a asp-page="/Importacoes/Index" class="text-muted small">← Ver importações anteriores</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Desabilita o botão e exibe spinner durante o upload
        document.getElementById('formUpload').addEventListener('submit', function () {
            document.getElementById('textoBtn').classList.add('d-none');
            document.getElementById('loadingBtn').classList.remove('d-none');
            document.getElementById('btnImportar').disabled = true;
        });
    </script>
}
